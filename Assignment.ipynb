    "import numpy as np\n",
    "from numpy.random import randn"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 309,
   "id": "5823f347-3cfe-4bb4-ab71-31ee92d39c95",
   "metadata": {},
